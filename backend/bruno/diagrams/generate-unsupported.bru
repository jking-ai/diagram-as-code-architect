meta {
  name: Generate Unsupported Combo (400)
  type: http
  seq: 5
}

post {
  url: {{host}}/api/v1/diagrams/generate
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "code": "resource \"google_compute_network\" \"vpc\" { name = \"main-vpc\" }",
    "diagramType": "SEQUENCE",
    "codeLanguage": "HCL"
  }
}

assert {
  res.status: eq 400
  res.body.error: eq UNSUPPORTED_DIAGRAM_TYPE
}
