# GCP project ID (used by Vertex AI, Jib, and Firebase)
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Run backend URL (used by demo script and functions proxy)
CLOUD_RUN_URL=https://your-cloud-run-url

# Vertex AI region
GCP_LOCATION=us-central1

# API key for backend authentication (production: from GCP Secret Manager)
API_KEY=your-api-key
